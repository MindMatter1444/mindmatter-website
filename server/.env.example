# Resend API-nøkkel — hent fra resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# hCaptcha secret — hent fra dashboard.hcaptcha.com
HCAPTCHA_SECRET_KEY=0xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxh

# Port API-serveren lytter på (standard 3001)
PORT=3001

# Sett til true for å omgå hCaptcha i lokal dev (bruk ?devBypass=1 i URL)
# CONTACT_DEV_BYPASS=true
